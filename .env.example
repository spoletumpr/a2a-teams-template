# Example environment variables for local development
# Copy this file to `.env` and set real values. Do NOT commit secrets.

# The A2A endpoint for the configured kagent Agent. HTTPS required for external hosts.
KAGENT_A2A_URL=https://kagent.example.com

# Azure Bot / Microsoft identity
# Required: application (client) ID from App Registration
MICROSOFT_APP_ID=00000000-0000-0000-0000-000000000000
# Optional: application secret. Prefer using a secret manager in production.
MICROSOFT_APP_PASSWORD=
# Required: tenant ID (directory ID) for SingleTenant or MultiTenant deployments
MICROSOFT_APP_TENANT_ID=00000000-0000-0000-0000-000000000000
# One of: SingleTenant | MultiTenant | UserAssignedMSI
MICROSOFT_APP_TYPE=SingleTenant

# Optional: comma-separated list of allowed Teams tenant IDs. If empty, only
# MICROSOFT_APP_TENANT_ID is accepted.
TEAMS_TENANT_ALLOWLIST=

# Boolean (true/false). When true, connector only accepts turns where the bot
# was explicitly mentioned in channel/group chats. Default: true
TEAMS_MENTION_ONLY=true

# Boolean (true/false). When true, outbound Teams mention markup is preserved.
# Default: false (recommended for safety).
TEAMS_ALLOW_OUTBOUND_MENTIONS=false

# Boolean (true/false). When true, connector forwards a hashed user identifier
# to kagent. Defaults to false.
KAGENT_FORWARD_USER_ID=false

# Logging level: error | warn | info | debug | trace
LOG_LEVEL=info

# HTTP port to listen on
PORT=3978
KAGENT_A2A_URL=http://kagent-controller.kagent.svc.cluster.local:8083/api/a2a/kagent/k8s-agent
MICROSOFT_APP_ID=00000000-0000-0000-0000-000000000000
MICROSOFT_APP_PASSWORD=
MICROSOFT_APP_TENANT_ID=00000000-0000-0000-0000-000000000000
MICROSOFT_APP_TYPE=SingleTenant
TEAMS_TENANT_ALLOWLIST=
TEAMS_MENTION_ONLY=
TEAMS_ALLOW_OUTBOUND_MENTIONS=false
KAGENT_FORWARD_USER_ID=false
LOG_LEVEL=info
PORT=3978
